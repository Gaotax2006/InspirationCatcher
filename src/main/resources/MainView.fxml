<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.web.WebView?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.inspiration.catcher.controller.MainController"
            prefWidth="1200" prefHeight="800">

    <!-- ================================================================
         CENTER: Navigation Rail | Sidebar | Workspace
         ================================================================ -->
    <center>
        <HBox spacing="0">
            <!-- ============================================================
                 COL 1: Navigation Rail — 48px dark sidebar
                 ============================================================ -->
            <VBox styleClass="nav-rail">
                <StackPane styleClass="nav-brand" prefWidth="32" prefHeight="32">
                    <FontIcon iconLiteral="fth-zap" iconSize="16"/>
                </StackPane>

                <Region minHeight="8"/>

                <VBox styleClass="nav-rail-center" VBox.vgrow="ALWAYS">
                    <Button styleClass="nav-item" onAction="#switchToIdeaList">
                        <graphic><FontIcon iconLiteral="fth-home" iconSize="20"/></graphic>
                        <tooltip><Tooltip text="灵感列表"/></tooltip>
                    </Button>
                    <Button styleClass="nav-item" onAction="#switchToMindMap">
                        <graphic><FontIcon iconLiteral="fth-share-2" iconSize="20"/></graphic>
                        <tooltip><Tooltip text="思维导图"/></tooltip>
                    </Button>
                    <Button styleClass="nav-item" onAction="#switchToEditor">
                        <graphic><FontIcon iconLiteral="fth-edit-3" iconSize="20"/></graphic>
                        <tooltip><Tooltip text="编辑器"/></tooltip>
                    </Button>
                </VBox>

                <VBox styleClass="nav-rail-bottom">
                    <Button styleClass="nav-item" onAction="#focusSearch">
                        <graphic><FontIcon iconLiteral="fth-search" iconSize="20"/></graphic>
                        <tooltip><Tooltip text="搜索"/></tooltip>
                    </Button>
                    <Button styleClass="nav-item" onAction="#handleAISettings">
                        <graphic><FontIcon iconLiteral="fth-settings" iconSize="20"/></graphic>
                        <tooltip><Tooltip text="设置"/></tooltip>
                    </Button>
                </VBox>
            </VBox>

            <!-- ============================================================
                 COL 2: Sidebar — project selector + search + filters
                 ============================================================ -->
            <VBox styleClass="library-panel" spacing="0">
                <!-- Logo area -->
                <HBox styleClass="sidebar-logo" spacing="10" alignment="CENTER_LEFT">
                    <StackPane styleClass="sidebar-logo-icon">
                        <FontIcon iconLiteral="fth-zap" iconSize="20"/>
                    </StackPane>
                    <Label text="灵感捕手" styleClass="sidebar-logo-text"/>
                </HBox>

                <HBox styleClass="library-header" spacing="6">
                    <ComboBox fx:id="projectSelector" prefWidth="130" styleClass="combo-box"/>
                    <Button onAction="#handleNewProject" styleClass="button-icon"
                            prefWidth="28" prefHeight="28">
                        <graphic><FontIcon iconLiteral="fth-folder-plus" iconSize="14"/></graphic>
                        <tooltip><Tooltip text="新建项目"/></tooltip>
                    </Button>
                    <Button onAction="#handleQuickCapture" styleClass="button-primary"
                            prefWidth="32" prefHeight="32" minWidth="32">
                        <graphic><FontIcon iconLiteral="fth-plus" iconSize="16"/></graphic>
                    </Button>
                </HBox>

                <TextField fx:id="searchField" promptText="搜索灵感..."
                           styleClass="library-search" HBox.hgrow="ALWAYS">
                    <HBox.margin><Insets left="12" right="12" bottom="8"/></HBox.margin>
                </TextField>

                <TitledPane text="过滤器" animated="true" collapsible="true" expanded="false"
                            styleClass="titled-pane">
                    <VBox spacing="6" style="-fx-padding: 0 12 12 12;">
                        <HBox spacing="6" alignment="CENTER_LEFT">
                            <Label text="类型" minWidth="36" styleClass="text-xs text-tertiary"/>
                            <ComboBox fx:id="typeFilter" promptText="所有类型" HBox.hgrow="ALWAYS"/>
                        </HBox>
                        <HBox spacing="6" alignment="CENTER_LEFT">
                            <Label text="重要性" minWidth="36" styleClass="text-xs text-tertiary"/>
                            <ComboBox fx:id="importanceFilter" promptText="所有级别" HBox.hgrow="ALWAYS"/>
                        </HBox>
                        <HBox spacing="6" alignment="CENTER_LEFT">
                            <Label text="心情" minWidth="36" styleClass="text-xs text-tertiary"/>
                            <ComboBox fx:id="moodFilter" promptText="所有心情" HBox.hgrow="ALWAYS"/>
                        </HBox>
                        <HBox spacing="6" alignment="CENTER_LEFT">
                            <Label text="标签" minWidth="36" styleClass="text-xs text-tertiary"/>
                            <ComboBox fx:id="tagFilter" promptText="选择标签" HBox.hgrow="ALWAYS"/>
                        </HBox>
                        <HBox spacing="6" alignment="CENTER_LEFT">
                            <DatePicker fx:id="startDateFilter" promptText="开始日期" HBox.hgrow="ALWAYS"/>
                            <Label text="至" styleClass="text-xs text-tertiary"/>
                            <DatePicker fx:id="endDateFilter" promptText="结束日期" HBox.hgrow="ALWAYS"/>
                        </HBox>
                        <HBox spacing="6" alignment="CENTER_RIGHT">
                            <Button text="应用" onAction="#updateFilterPredicate" styleClass="button-primary button-sm"/>
                            <Button text="重置" onAction="#resetAllFilters" styleClass="button-ghost button-sm"/>
                        </HBox>
                    </VBox>
                </TitledPane>

                <VBox spacing="4" style="-fx-padding: 4 12 0 12;">
                    <Label text="热门标签" styleClass="library-section-title"/>
                    <FlowPane fx:id="tagCloud" hgap="5" vgap="5" prefHeight="60" maxHeight="80"/>
                </VBox>

                <Region VBox.vgrow="ALWAYS"/>

                <!-- Statistics in sidebar footer -->
                <VBox spacing="3" style="-fx-padding: 8 12;">
                    <Label text="统计" styleClass="library-section-title"/>
                    <HBox spacing="8">
                        <Label fx:id="totalIdeasLabel" styleClass="text-xs text-tertiary"/>
                        <Label fx:id="weeklyIdeasLabel" styleClass="text-xs text-tertiary"/>
                    </HBox>
                </VBox>
            </VBox>

            <!-- ============================================================
                 COL 3: Workspace
                 ============================================================ -->
            <VBox styleClass="workspace" HBox.hgrow="ALWAYS">

                <!-- Minimal workspace toolbar -->
                <HBox styleClass="workspace-toolbar" spacing="4">
                    <Label styleClass="text-xs text-tertiary"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button onAction="#handleDecreaseFont" styleClass="button-icon"
                            prefWidth="28" prefHeight="28">
                        <graphic><FontIcon iconLiteral="fth-minus" iconSize="14"/></graphic>
                        <tooltip><Tooltip text="减小字体"/></tooltip>
                    </Button>
                    <Button onAction="#showFontDialog" styleClass="button-icon"
                            prefWidth="28" prefHeight="28">
                        <graphic><FontIcon iconLiteral="fth-type" iconSize="14"/></graphic>
                        <tooltip><Tooltip text="字体设置"/></tooltip>
                    </Button>
                    <Button onAction="#handleIncreaseFont" styleClass="button-icon"
                            prefWidth="28" prefHeight="28">
                        <graphic><FontIcon iconLiteral="fth-plus" iconSize="14"/></graphic>
                        <tooltip><Tooltip text="增大字体"/></tooltip>
                    </Button>
                </HBox>

                <!-- TabPane: Idea List | Mind Map | Editor -->
                <TabPane fx:id="mainTabPane" tabClosingPolicy="UNAVAILABLE" VBox.vgrow="ALWAYS">

                    <!-- ===== TAB 1: 灵感列表 ===== -->
                    <Tab text="灵感列表">
                        <VBox spacing="0" styleClass="workspace-content">
                            <!-- Header row -->
                            <HBox spacing="8" alignment="CENTER_LEFT"
                                  style="-fx-padding: 12 20 8 20;">
                                <Label text="灵感列表" styleClass="page-title"/>
                                <Region HBox.hgrow="ALWAYS"/>
                                <Button text="刷新" onAction="#refreshTableData"
                                        styleClass="button-ghost button-sm"/>
                                <Button text="新建" onAction="#handleNewIdea"
                                        styleClass="button-primary button-sm"/>
                                <Button text="编辑" onAction="#handleEditIdea"
                                        styleClass="button-outline button-sm"/>
                                <Button text="删除" onAction="#handleDeleteIdea"
                                        styleClass="button-danger button-sm"/>
                                <Separator orientation="VERTICAL"/>
                                <Button text="导出 JSON" onAction="#handleExportJson"
                                        styleClass="button-ghost button-sm"/>
                                <Button text="导出 MD" onAction="#handleExportMarkdown"
                                        styleClass="button-ghost button-sm"/>
                                <Separator orientation="VERTICAL"/>
                                <Button onAction="#handleCleanUnusedTags" styleClass="button-icon"
                                        prefWidth="28" prefHeight="28">
                                    <graphic><FontIcon iconLiteral="fth-tag" iconSize="14"/></graphic>
                                    <tooltip><Tooltip text="清理未使用标签"/></tooltip>
                                </Button>
                                <Button onAction="#showTagStats" styleClass="button-icon"
                                        prefWidth="28" prefHeight="28">
                                    <graphic><FontIcon iconLiteral="fth-bar-chart-2" iconSize="14"/></graphic>
                                    <tooltip><Tooltip text="标签统计"/></tooltip>
                                </Button>
                            </HBox>

                            <!-- Table -->
                            <TableView fx:id="ideaTableView" VBox.vgrow="ALWAYS"
                                       style="-fx-padding: 0 12 0 12;">
                                <columns>
                                    <TableColumn text="标题" fx:id="titleColumn" prefWidth="200"/>
                                    <TableColumn text="类型" fx:id="typeColumn" prefWidth="80"/>
                                    <TableColumn text="重要性" fx:id="importanceColumn" minWidth="80" prefWidth="100"/>
                                    <TableColumn text="心情" fx:id="moodColumn" prefWidth="80"/>
                                    <TableColumn text="标签" fx:id="tagsColumn" prefWidth="200"/>
                                    <TableColumn text="创建时间" fx:id="createdAtColumn" prefWidth="180"/>
                                    <TableColumn text="更新时间" fx:id="updatedAtColumn" prefWidth="180"/>
                                </columns>
                            </TableView>

                            <!-- Collapsible detail panel (appears when row selected) -->
                            <VBox fx:id="detailPanel" managed="false" visible="false"
                                  style="-fx-padding: 8 12 12 12;">
                                <HBox spacing="6" alignment="CENTER_LEFT">
                                    <Label text="详情" styleClass="library-section-title"/>
                                    <Region HBox.hgrow="ALWAYS"/>
                                    <Button text="编辑" onAction="#handleEditIdea"
                                            styleClass="button-ghost button-sm"/>
                                </HBox>
                                <TextArea fx:id="ideaDetail" wrapText="true" editable="false"
                                          prefHeight="120" maxHeight="200"
                                          style="-fx-font-size: 12px;"/>
                            </VBox>
                        </VBox>
                    </Tab>

                    <!-- ===== TAB 2: 思维导图 ===== -->
                    <Tab text="思维导图">
                        <HBox spacing="0">
                            <!-- Left: idea card list (drag source) — clearly bounded panel -->
                            <VBox spacing="8"
                                  prefWidth="240" minWidth="200"
                                  style="-fx-background-color: -fx-bg-raised; -fx-border-color: -fx-border-subtle; -fx-border-width: 0 1 0 0; -fx-padding: 12;">
                                <Label text="灵感卡片" styleClass="text-sm text-semibold text-secondary"/>
                                <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                                            style="-fx-background-color: transparent; -fx-border-color: transparent;">
                                    <VBox fx:id="mindMapIdeaListContainer" spacing="6" style="-fx-padding: 2;"/>
                                </ScrollPane>
                                <!-- Quick actions at bottom -->
                                <HBox spacing="6" alignment="CENTER_LEFT"
                                      style="-fx-padding: 8 0 0 0; -fx-border-color: -fx-border-subtle transparent transparent transparent; -fx-border-width: 1 0 0 0;">
                                    <Button text="+概念" onAction="#handleAddConceptNodeToMindMap"
                                            styleClass="button-ghost button-sm"/>
                                    <Button text="+链接" onAction="#handleAddExternalNodeToMindMap"
                                            styleClass="button-ghost button-sm"/>
                                    <Region HBox.hgrow="ALWAYS"/>
                                    <Button onAction="#refreshMindMapIdeaList"
                                            styleClass="button-icon" prefWidth="26" prefHeight="26">
                                        <graphic><FontIcon iconLiteral="fth-refresh-cw" iconSize="14"/></graphic>
                                    </Button>
                                </HBox>
                            </VBox>

                            <!-- Right: canvas with clear boundary frame -->
                            <BorderPane HBox.hgrow="ALWAYS"
                                        style="-fx-background-color: -fx-bg-subtle;">
                                <top>
                                    <HBox spacing="6" alignment="CENTER_LEFT"
                                          style="-fx-padding: 8 16; -fx-background-color: -fx-bg; -fx-border-color: transparent transparent -fx-border-subtle transparent; -fx-border-width: 0 0 1 0;">
                                        <Label text="思维导图" styleClass="text-sm text-medium"/>
                                        <Region HBox.hgrow="ALWAYS"/>
                                        <Button text="添加灵感" onAction="#handleAddIdeaNodeToMindMap"
                                                styleClass="button-outline button-sm"/>
                                        <Button text="自动布局" onAction="#handleAutoLayout" styleClass="button-ghost button-sm"/>
                                        <Button text="导出图片" onAction="#handleExportMindMapImage" styleClass="button-ghost button-sm"/>
                                    </HBox>
                                </top>
                                <center>
                                    <Pane fx:id="mindMapPane"
                                          style="-fx-background-color: -fx-bg; -fx-border-color: -fx-border-subtle; -fx-border-width: 0; -fx-background-radius: 0;"/>
                                </center>
                                <!-- Bottom-left hint -->
                                <bottom>
                                    <HBox spacing="6" alignment="CENTER_LEFT"
                                          style="-fx-padding: 4 12; -fx-background-color: -fx-bg-subtle; -fx-border-color: -fx-border-subtle transparent transparent transparent; -fx-border-width: 1 0 0 0;">
                                        <Label text="拖拽左侧卡片到画布添加节点 · 双击编辑 · 滚轮缩放" styleClass="text-xs text-tertiary"/>
                                    </HBox>
                                </bottom>
                            </BorderPane>
                        </HBox>
                    </Tab>

                    <!-- ===== TAB 3: 编辑器 ===== -->
                    <Tab text="编辑器">
                        <VBox spacing="0" styleClass="workspace-content">
                            <!-- Title + Meta row -->
                            <HBox spacing="8" alignment="CENTER_LEFT"
                                  style="-fx-padding: 12 20 6 20;">
                                <TextField fx:id="editorTitleField" HBox.hgrow="ALWAYS"
                                           promptText="灵感标题（可选）" styleClass="text-lg text-semibold"/>
                                <Button text="保存" onAction="#handleSave"
                                        styleClass="button-primary button-sm"/>
                                <Button text="AI 扩展" onAction="#generateAIExpansion"
                                        styleClass="button-outline button-sm"/>
                            </HBox>

                            <HBox spacing="8" alignment="CENTER_LEFT"
                                  style="-fx-padding: 4 20 8 20;">
                                <ComboBox fx:id="editorTypeCombo" promptText="类型" prefWidth="110"/>
                                <Spinner fx:id="editorImportanceSpinner" min="1" max="5"
                                         initialValue="3" prefWidth="80" editable="true"/>
                                <ComboBox fx:id="editorMoodCombo" promptText="心情" prefWidth="110"/>
                                <TextField fx:id="editorTagsField" promptText="输入标签，用逗号或空格分隔"
                                           HBox.hgrow="ALWAYS"/>
                            </HBox>

                            <!-- Editor + Preview SplitPane -->
                            <SplitPane dividerPositions="0.55" VBox.vgrow="ALWAYS"
                                       style="-fx-padding: 0 12 0 12;">
                                <!-- Left: Markdown editor -->
                                <VBox spacing="4">
                                    <!-- Markdown toolbar -->
                                    <HBox spacing="3" style="-fx-padding: 4 0;" alignment="CENTER_LEFT">
                                        <Button text="B" onAction="#handleBold" styleClass="button-toolbar"/>
                                        <Button text="I" onAction="#handleItalic" styleClass="button-toolbar"/>
                                        <Separator orientation="VERTICAL"/>
                                        <Button text="H1" onAction="#handleHeader1" styleClass="button-toolbar"/>
                                        <Button text="H2" onAction="#handleHeader2" styleClass="button-toolbar"/>
                                        <Separator orientation="VERTICAL"/>
                                        <Button text="{" onAction="#handleCode" styleClass="button-toolbar"/>
                                        <Button text="•" onAction="#handleList" styleClass="button-toolbar"/>
                                        <Button text=">" onAction="#handleQuote" styleClass="button-toolbar"/>
                                        <Separator orientation="VERTICAL"/>
                                        <Button text="🔗" onAction="#handleLink" styleClass="button-toolbar"/>
                                        <Button text="🖼" onAction="#handleImage" styleClass="button-toolbar"/>
                                        <Region HBox.hgrow="ALWAYS"/>
                                        <Button text="大纲" onAction="#generateOutline"
                                                styleClass="button-ghost button-sm"/>
                                        <Button text="预览" onAction="#refreshPreview"
                                                styleClass="button-ghost button-sm"/>
                                    </HBox>

                                    <TextArea fx:id="markdownEditor" promptText="在此输入内容（支持Markdown）..."
                                              VBox.vgrow="ALWAYS" wrapText="true"/>
                                </VBox>

                                <!-- Right: WebView Preview -->
                                <VBox spacing="4">
                                    <HBox spacing="6" alignment="CENTER_LEFT"
                                          style="-fx-padding: 4 0;">
                                        <Label text="预览" styleClass="text-sm text-tertiary"/>
                                        <Region HBox.hgrow="ALWAYS"/>
                                    </HBox>
                                    <WebView fx:id="markdownPreview" VBox.vgrow="ALWAYS"/>
                                </VBox>
                            </SplitPane>

                            <!-- Bottom: AI Suggestions + Related Ideas -->
                            <VBox spacing="4" style="-fx-padding: 8 12 12 12;">
                                <TitledPane text="AI 建议" animated="true" collapsible="true" expanded="false">
                                    <VBox spacing="6" style="-fx-padding: 8;">
                                        <HBox spacing="5" alignment="CENTER_RIGHT">
                                            <Button text="生成建议" onAction="#generateAISuggestions"
                                                    styleClass="button-outline button-sm"/>
                                            <Button text="AI 扩展" onAction="#generateAIExpansion"
                                                    styleClass="button-outline button-sm"/>
                                            <Button text="测试连接" onAction="#testAIConnection"
                                                    styleClass="button-ghost button-sm"/>
                                        </HBox>
                                        <TextArea fx:id="aiSuggestions" wrapText="true"
                                                  VBox.vgrow="ALWAYS" editable="false"
                                                  prefHeight="120" maxHeight="200"
                                                  styleClass="text-area-ai"/>
                                    </VBox>
                                </TitledPane>
                                <TitledPane text="相关灵感" animated="true" collapsible="true" expanded="false">
                                    <ListView fx:id="relatedIdeasList" prefHeight="100" maxHeight="150"/>
                                </TitledPane>
                            </VBox>
                        </VBox>
                    </Tab>
                </TabPane>
            </VBox>
        </HBox>
    </center>

    <!-- ================================================================
         BOTTOM: Status Bar
         ================================================================ -->
    <bottom>
        <HBox spacing="12" styleClass="status-bar" style="-fx-padding: 4 16;">
            <Label text="就绪" fx:id="statusLabel" styleClass="text-xs"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="topTagLabel" styleClass="text-xs text-tertiary"/>
        </HBox>
    </bottom>

</BorderPane>
