<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.web.WebView?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.inspiration.catcher.controller.MainController"
            prefWidth="1200" prefHeight="800">

    <!-- 顶部菜单栏 + 工具栏 -->
    <top>
        <VBox>
            <MenuBar>
                <Menu text="文件">
                    <MenuItem text="新建灵感" onAction="#handleNewIdea" accelerator="Ctrl+N"/>
                    <MenuItem text="新建项目" onAction="#handleNewProject"/>
                    <SeparatorMenuItem/>
                    <MenuItem text="快速捕捉" onAction="#handleQuickCapture" accelerator="Ctrl+Q"/>
                    <SeparatorMenuItem/>
                    <MenuItem text="退出" onAction="#handleExit" accelerator="Ctrl+Q"/>
                </Menu>
                <Menu text="工具">
                    <MenuItem text="AI 设置" onAction="#handleAISettings"/>
                    <MenuItem text="清理未使用标签" onAction="#handleCleanUnusedTags"/>
                    <MenuItem text="标签统计" onAction="#showTagStats"/>
                    <SeparatorMenuItem/>
                    <MenuItem text="测试 AI 连接" onAction="#testAIConnection"/>
                </Menu>
                <Menu text="视图">
                    <MenuItem text="增大字体" onAction="#handleIncreaseFont" accelerator="Ctrl+EQUALS"/>
                    <MenuItem text="减小字体" onAction="#handleDecreaseFont" accelerator="Ctrl+MINUS"/>
                    <MenuItem text="重置字体" onAction="#handleResetFont"/>
                    <SeparatorMenuItem/>
                    <CheckMenuItem text="状态栏" selected="true" disable="true"/>
                </Menu>
                <Menu text="帮助">
                    <MenuItem text="关于灵感捕手" disable="true"/>
                </Menu>
            </MenuBar>

            <!-- 工具栏 -->
            <HBox spacing="8" styleClass="tool-bar" stylesheets="@css/main.css">
                <Label text="项目:"/>
                <ComboBox fx:id="projectSelector" prefWidth="180" styleClass="combo-box-project"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="测试 AI" onAction="#testAIConnection" styleClass="button-warning"/>
                <Separator orientation="VERTICAL"/>
                <Button text="A-" onAction="#handleDecreaseFont" styleClass="button-ghost"/>
                <Button text="字体" onAction="#showFontDialog" styleClass="button-ghost"/>
                <Button text="A+" onAction="#handleIncreaseFont" styleClass="button-ghost"/>
                <Button text="重置" onAction="#handleResetFont" styleClass="button-ghost"/>
                <Separator orientation="VERTICAL"/>
                <Button text="保存" onAction="#handleSave" styleClass="button-primary"/>
                <Button text="清理标签" onAction="#handleCleanUnusedTags" styleClass="button-ghost"/>
            </HBox>
        </VBox>
    </top>

    <center>
        <SplitPane dividerPositions="0.12, 0.88">
            <!-- ===== 左侧面板 ===== -->
            <VBox spacing="8" styleClass="left-panel" stylesheets="@css/main.css">
                <Label text="灵感捕手" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: -fx-primary;"/>
                <Separator/>
                <Button text="快速捕捉" onAction="#handleQuickCapture" styleClass="quick-capture-btn"/>
                <TextField fx:id="searchField" promptText="搜索灵感..." />

                <TitledPane text="过滤器" animated="true" collapsible="true" expanded="false">
                    <VBox spacing="6">
                        <HBox spacing="5" alignment="CENTER_LEFT">
                            <Label text="类型" minWidth="40" style="-fx-font-size: 12px;"/>
                            <ComboBox fx:id="typeFilter" promptText="所有类型" HBox.hgrow="ALWAYS"/>
                        </HBox>
                        <HBox spacing="5" alignment="CENTER_LEFT">
                            <Label text="重要性" minWidth="40" style="-fx-font-size: 12px;"/>
                            <ComboBox fx:id="importanceFilter" promptText="所有级别" HBox.hgrow="ALWAYS"/>
                        </HBox>
                        <HBox spacing="5" alignment="CENTER_LEFT">
                            <Label text="心情" minWidth="40" style="-fx-font-size: 12px;"/>
                            <ComboBox fx:id="moodFilter" promptText="所有心情" HBox.hgrow="ALWAYS"/>
                        </HBox>
                        <HBox spacing="5" alignment="CENTER_LEFT">
                            <Label text="标签" minWidth="40" style="-fx-font-size: 12px;"/>
                            <ComboBox fx:id="tagFilter" promptText="选择标签" HBox.hgrow="ALWAYS"/>
                        </HBox>
                        <HBox spacing="5" alignment="CENTER_LEFT">
                            <DatePicker fx:id="startDateFilter" promptText="开始日期" HBox.hgrow="ALWAYS"/>
                            <Label text="至" style="-fx-font-size: 12px;"/>
                            <DatePicker fx:id="endDateFilter" promptText="结束日期" HBox.hgrow="ALWAYS"/>
                        </HBox>
                        <HBox spacing="5" alignment="CENTER_RIGHT">
                            <Button text="应用" onAction="#updateFilterPredicate" styleClass="button-primary"/>
                            <Button text="重置" onAction="#resetAllFilters" styleClass="button-ghost"/>
                        </HBox>
                    </VBox>
                </TitledPane>

                <VBox spacing="4">
                    <Label text="热门标签" styleClass="section-title"/>
                    <FlowPane fx:id="tagCloud" hgap="5" vgap="5"/>
                </VBox>
            </VBox>

            <!-- ===== 中间 TabPane ===== -->
            <TabPane fx:id="mainTabPane" tabClosingPolicy="UNAVAILABLE">
                <!-- 灵感列表 -->
                <Tab text="灵感列表">
                    <VBox spacing="8" styleClass="content-area" stylesheets="@css/main.css">
                        <HBox spacing="8" alignment="CENTER_LEFT">
                            <Label text="灵感列表" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Button text="刷新" onAction="#resetAllFilters" styleClass="button-ghost"/>
                            <Button text="新建" onAction="#handleNewIdea" styleClass="button-primary"/>
                            <Button text="编辑" onAction="#handleEditIdea" styleClass="button-ghost"/>
                            <Button text="删除" onAction="#handleDeleteIdea" styleClass="button-danger"/>
                        </HBox>
                        <TableView fx:id="ideaTableView" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn text="标题" fx:id="titleColumn"/>
                                <TableColumn text="类型" fx:id="typeColumn"/>
                                <TableColumn text="重要性" fx:id="importanceColumn" minWidth="80"/>
                                <TableColumn text="心情" fx:id="moodColumn"/>
                                <TableColumn text="标签" fx:id="tagsColumn" prefWidth="200"/>
                                <TableColumn text="创建时间" fx:id="createdAtColumn" prefWidth="200"/>
                                <TableColumn text="更新时间" fx:id="updatedAtColumn" prefWidth="200"/>
                            </columns>
                        </TableView>
                    </VBox>
                </Tab>

                <!-- 思维导图 -->
                <Tab text="思维导图">
                    <BorderPane>
                        <top>
                            <HBox spacing="8" styleClass="tool-bar" stylesheets="@css/main.css">
                                <Button text="添加概念" onAction="#handleAddConceptNodeToMindMap" styleClass="button-ghost"/>
                                <Button text="自动布局" onAction="#handleAddIdeaNodeToMindMap" styleClass="button-ghost"/>
                                <Region HBox.hgrow="ALWAYS"/>
                                <Button text="导出图片" styleClass="button-ghost" />
                            </HBox>
                        </top>
                        <center>
                            <Pane fx:id="mindMapPane" />
                        </center>
                    </BorderPane>
                </Tab>

                <!-- 编辑器 -->
                <Tab text="编辑器">
                    <SplitPane dividerPositions="0.55">
                        <!-- 左侧编辑器 -->
                        <VBox spacing="6">
                            <HBox spacing="8" alignment="CENTER_LEFT">
                                <Label text="标题" minWidth="40"/>
                                <TextField fx:id="editorTitleField" HBox.hgrow="ALWAYS" promptText="灵感标题（可选）"/>
                            </HBox>
                            <HBox spacing="8" alignment="CENTER_LEFT">
                                <ComboBox fx:id="editorTypeCombo" promptText="类型" prefWidth="120"/>
                                <Spinner fx:id="editorImportanceSpinner" min="1" max="5" initialValue="3" prefWidth="80"/>
                                <ComboBox fx:id="editorMoodCombo" prefWidth="120"/>
                            </HBox>
                            <TextField fx:id="editorTagsField" promptText="输入标签，用逗号或空格分隔"/>
                            <!-- Markdown 工具栏 -->
                            <HBox spacing="3" styleClass="tool-bar" stylesheets="@css/main.css">
                                <Button text="B" onAction="#handleBold" styleClass="button-toolbar"/>
                                <Button text="I" onAction="#handleItalic" styleClass="button-toolbar"/>
                                <Separator orientation="VERTICAL"/>
                                <Button text="H1" onAction="#handleHeader1" styleClass="button-toolbar"/>
                                <Button text="H2" onAction="#handleHeader2" styleClass="button-toolbar"/>
                                <Separator orientation="VERTICAL"/>
                                <Button text="{" onAction="#handleCode" styleClass="button-toolbar"/>
                                <Button text="•" onAction="#handleList" styleClass="button-toolbar"/>
                                <Button text=">" onAction="#handleQuote" styleClass="button-toolbar"/>
                                <Separator orientation="VERTICAL"/>
                                <Button text="🔗" onAction="#handleLink" styleClass="button-toolbar"/>
                                <Button text="🖼" onAction="#handleImage" styleClass="button-toolbar"/>
                                <Region HBox.hgrow="ALWAYS"/>
                                <Button text="大纲" onAction="#generateOutline" styleClass="button-ghost"/>
                            </HBox>
                            <TextArea fx:id="markdownEditor" promptText="在此输入内容（支持Markdown）..."
                                      VBox.vgrow="ALWAYS" wrapText="true"
                                      style="-fx-font-family: 'Consolas', 'Monaco', monospace; -fx-font-size: 14px;"/>
                        </VBox>
                        <!-- 右侧预览 -->
                        <VBox spacing="6">
                            <HBox spacing="8">
                                <Button text="保存" onAction="#handleSave" styleClass="button-primary"/>
                                <Button text="AI 扩展" onAction="#generateAIExpansion" styleClass="button-warning"/>
                                <Button text="刷新预览" onAction="#refreshPreview" styleClass="button-ghost"/>
                            </HBox>
                            <WebView fx:id="markdownPreview" VBox.vgrow="ALWAYS"/>
                        </VBox>
                    </SplitPane>
                </Tab>
            </TabPane>

            <!-- ===== 右侧面板 ===== -->
            <VBox spacing="6" styleClass="right-panel" stylesheets="@css/main.css">
                <TabPane tabClosingPolicy="UNAVAILABLE" VBox.vgrow="ALWAYS">
                    <Tab text="详情">
                        <VBox spacing="4">
                            <TextArea fx:id="ideaDetail" wrapText="true" VBox.vgrow="ALWAYS" editable="false"/>
                        </VBox>
                    </Tab>
                    <Tab text="AI 建议">
                        <VBox spacing="4">
                            <HBox spacing="5">
                                <Region HBox.hgrow="ALWAYS"/>
                                <Button text="生成" onAction="#generateAISuggestions" styleClass="button-warning"/>
                            </HBox>
                            <TextArea fx:id="aiSuggestions" wrapText="true" VBox.vgrow="ALWAYS" editable="false" styleClass="text-area-ai"/>
                        </VBox>
                    </Tab>
                    <Tab text="相关">
                        <ListView fx:id="relatedIdeasList"/>
                    </Tab>
                </TabPane>
                <!-- 统计信息 -->
                <VBox spacing="2" style="-fx-padding: 8 4;">
                    <Label text="统计" styleClass="section-title"/>
                    <Label text="灵感总数：0" fx:id="totalIdeasLabel" style="-fx-font-size: 12px;"/>
                    <Label text="本周新增：0" fx:id="weeklyIdeasLabel" style="-fx-font-size: 12px;"/>
                    <Label text="最活跃标签：无" fx:id="topTagLabel" style="-fx-font-size: 12px;"/>
                </VBox>
            </VBox>
        </SplitPane>
    </center>

    <!-- 底部状态栏 -->
    <bottom>
        <HBox spacing="10" styleClass="status-bar">
            <Label text="就绪" fx:id="statusLabel"/>
            <Region HBox.hgrow="ALWAYS"/>
        </HBox>
    </bottom>
</BorderPane>
