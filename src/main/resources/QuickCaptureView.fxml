<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.inspiration.catcher.controller.QuickCaptureController"
      spacing="10"
      style="-fx-padding: 16; -fx-background-color: -fx-bg;"
      alignment="TOP_CENTER"
      stylesheets="@css/theme.css,@css/components.css">

    <Label text="快速捕捉灵感" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: -fx-primary;"/>

    <HBox spacing="10" alignment="CENTER_LEFT">
        <Label text="类型"/>
        <ComboBox fx:id="typeCombo" prefWidth="110"/>
        <Label text="重要性"/>
        <ComboBox fx:id="importanceCombo" prefWidth="70"/>
        <Label text="心情"/>
        <ComboBox fx:id="moodCombo" prefWidth="110"/>
    </HBox>

    <TextField fx:id="titleField"
               promptText="灵感标题（可选）"
               style="-fx-font-size: 14px;"/>

    <TextArea fx:id="contentArea"
              promptText="在此输入你的灵感..."
              wrapText="true"
              VBox.vgrow="ALWAYS"
              prefHeight="160"
              style="-fx-font-size: 14px;"/>

    <HBox spacing="5" alignment="CENTER_LEFT">
        <Label text="标签"/>
        <TextField fx:id="tagInput"
                   promptText="输入标签，多个用逗号分隔"
                   HBox.hgrow="ALWAYS"/>
        <Button text="添加" onAction="#handleAddTag" styleClass="button-primary"/>
    </HBox>

    <FlowPane fx:id="tagContainer" hgap="5" vgap="5"/>

    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Button text="取消" onAction="#handleCancel" styleClass="button-ghost"/>
        <Button text="保存" onAction="#handleSave" styleClass="button-success"/>
    </HBox>
</VBox>
